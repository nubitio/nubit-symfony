{
    "name": "nubitio/api-platform",
    "description": "API Platform bridge for the Nubit admin stack: data-grid filter (sort/filter/searchValue), translated OpenAPI docs with x-crud hints for @nubitio/hydra, pagination headers, and entity traits.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "symfony",
        "api-platform",
        "hydra",
        "crud",
        "datagrid",
        "nubit"
    ],
    "homepage": "https://github.com/nubitio/nubit-symfony/tree/main/packages/api-platform",
    "support": {
        "issues": "https://github.com/nubitio/nubit-symfony/issues",
        "source": "https://github.com/nubitio/nubit-symfony"
    },
    "require": {
        "api-platform/core": "^4.1",
        "doctrine/orm": "^3.0",
        "doctrine/persistence": "^4.0",
        "nubitio/platform": "0.*",
        "php": ">=8.5",
        "psr/log": "^3.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/event-dispatcher": "^7.4 || ^8.0",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/http-foundation": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "symfony/serializer": "^7.4 || ^8.0",
        "symfony/translation-contracts": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "symfony/translation": "^7.4 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Nubit\\ApiPlatform\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nubit\\ApiPlatform\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
