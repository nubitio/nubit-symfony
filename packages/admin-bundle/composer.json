{
    "name": "nubitio/admin-bundle",
    "description": "One-line Symfony bundle for the Nubit admin stack: API Platform grid contract, translated OpenAPI docs with x-crud hints, dual cookie/Bearer JWT auth, and single-tenant defaults. Pairs with @nubitio/react-admin.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "admin",
        "api-platform",
        "jwt",
        "crud",
        "nubit"
    ],
    "homepage": "https://github.com/nubitio/nubit-symfony/tree/main/packages/admin-bundle",
    "support": {
        "issues": "https://github.com/nubitio/nubit-symfony/issues",
        "source": "https://github.com/nubitio/nubit-symfony"
    },
    "require": {
        "php": ">=8.5",
        "doctrine/orm": "^3.0",
        "firebase/php-jwt": "^7.0",
        "nubitio/api-platform": "0.*",
        "nubitio/platform": "0.*",
        "psr/log": "^3.0",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/console": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/http-foundation": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "symfony/password-hasher": "^7.4 || ^8.0",
        "symfony/routing": "^7.4 || ^8.0",
        "symfony/security-bundle": "^7.4 || ^8.0",
        "symfony/security-core": "^7.4 || ^8.0",
        "symfony/security-http": "^7.4 || ^8.0",
        "symfony/translation-contracts": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nubit\\AdminBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nubit\\AdminBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
