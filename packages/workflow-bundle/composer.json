{
    "name": "nubitio/workflow-bundle",
    "description": "Opt-in state-machine kit for Nubit Symfony apps: Workflow attribute, transition API, and x-workflow OpenAPI hints.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "workflow",
        "state-machine",
        "nubit"
    ],
    "homepage": "https://github.com/nubitio/nubit-symfony/tree/main/packages/workflow-bundle",
    "support": {
        "issues": "https://github.com/nubitio/nubit-symfony/issues",
        "source": "https://github.com/nubitio/nubit-symfony"
    },
    "require": {
        "php": ">=8.3",
        "api-platform/core": "^4.1",
        "doctrine/orm": "^3.0",
        "nubitio/api-platform": "0.*",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/http-foundation": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "symfony/routing": "^7.4 || ^8.0",
        "symfony/security-core": "^7.4 || ^8.0",
        "symfony/serializer": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nubit\\WorkflowBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nubit\\WorkflowBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
